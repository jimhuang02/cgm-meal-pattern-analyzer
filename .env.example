# PostgreSQL connection string (required for production)
# On Render, this is set automatically from the linked database
# For local dev, leave unset to use SQLite fallback
DATABASE_URL=postgresql://user:password@host:5432/cgm_analyzer

# Anthropic API key for LLM insight generation
# If not set, the app runs in demo mode with a placeholder report
ANTHROPIC_API_KEY=sk-ant-...
